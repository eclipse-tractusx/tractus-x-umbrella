meta {
  name: AddBPNCredential
  type: http
  seq: 4
}

post {
  url: {{ISSUERSERVICE.URL}}/api/admin/v1alpha/participants/{{ISSUER_PARTICIPANT}}/credentialdefinitions
  body: json
  auth: apikey
}

auth:apikey {
  key: x-api-key
  value: {{ISSUER_API_KEY}}
  placement: header
}

body:json {
  {
    "attestations": ["attestation-id"],
    "credentialType": "BpnCredential",
    "format": "VC1_0_JWT",
    "id": "BpnCredential-id",
    "jsonSchema": "{}",
    "jsonSchemaUrl": "test",
    "mappings": [
      {
        "input": "holder_id",
        "output": "credentialSubject.id",
        "required": true
      },
      {
        "input": "bpn",
        "output": "credentialSubject.holderIdentifier",
        "required": true
      },
      {
        "input": "bpn",
        "output": "credentialSubject.bpn",
        "required": true
      }
    ],
  //   "rules": [
  //     {
      //    "configuration": {
      //      "additionalProp1": {},
      //      "additionalProp2": {},
      //      "additionalProp3": {}
      //    },
      //    "type": "string"
  //     }
  //   ],
    "validity": 10000000000000
  }
}

settings {
  encodeUrl: true
  timeout: 0
}
